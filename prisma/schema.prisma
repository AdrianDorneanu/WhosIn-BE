// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum GameStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  passwordHash    String?
  displayName     String
  avatarUrl       String?
  emailVerifiedAt DateTime?
  timezone        String?
  status          UserStatus @default(ACTIVE)

  organizedGames Game[] @relation("GameOrganizer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("users")
}

model Game {
  id       String @id @default(uuid()) @db.Uuid
  publicId String @unique

  organizerId String @db.Uuid
  organizer   User   @relation("GameOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)

  title       String
  sport       String
  startsAt    DateTime
  endsAt      DateTime
  location    String
  maxPlayers  Int
  status      GameStatus @default(UPCOMING)
  cancelledAt DateTime?  @db.Timestamptz(3)

  costPerPlayer Decimal? @db.Decimal(10, 2)
  notes         String?  @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerId])
  @@index([startsAt])
  @@index([status])
  @@map("games")
}
